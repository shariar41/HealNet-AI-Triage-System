<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003" ToolsVersion="4.0">
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>4c4ab1bf-eb59-4ddd-8dea-e4efdec31c69</ProjectGuid>
    <ProjectHome>.</ProjectHome>
    <StartupFile>app\app.py</StartupFile>
    <SearchPath>
    </SearchPath>
    <WorkingDirectory>.</WorkingDirectory>
    <OutputPath>.</OutputPath>
    <Name>HealNet_Saimon_IEEE</Name>
    <RootNamespace>HealNet_Saimon_IEEE</RootNamespace>
    <InterpreterId>MSBuild|IEEEContestENV|$(MSBuildProjectFullPath)</InterpreterId>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="app\app.py" />
    <Compile Include="config.py" />
    <Compile Include="HealNet_Saimon_IEEE.py" />
    <Compile Include="models\dqn_agent.py" />
    <Compile Include="models\image_model.py" />
    <Compile Include="models\replay_memory.py" />
    <Compile Include="models\symptom_model.py" />
    <Compile Include="training\analyze_saved_xray_model.py" />
    <Compile Include="training\build_rl_dataset.py" />
    <Compile Include="training\build_symptom2disease_features.py" />
    <Compile Include="training\preprocess_mendeley_data.py" />
    <Compile Include="training\preprocess_symptom_data.py" />
    <Compile Include="training\safety_rules.py" />
    <Compile Include="training\train_dqn.py" />
    <Compile Include="training\train_image_model.py" />
    <Compile Include="training\train_symptom_model.py" />
    <Compile Include="training\triage_mapping.py" />
    <Compile Include="training\visualize_xray_preprocessing.py" />
    <Compile Include="training\xray_preprocessing.py" />
    <Compile Include="utils.py" />
  </ItemGroup>
  <ItemGroup>
    <Interpreter Include="IEEEContestENV\">
      <Id>IEEEContestENV</Id>
      <Version>3.12</Version>
      <Description>IEEEContestENV (Python 3.12 (64-bit))</Description>
      <InterpreterPath>Scripts\python.exe</InterpreterPath>
      <WindowsInterpreterPath>Scripts\pythonw.exe</WindowsInterpreterPath>
      <PathEnvironmentVariable>PYTHONPATH</PathEnvironmentVariable>
      <Architecture>X64</Architecture>
    </Interpreter>
  </ItemGroup>
  <ItemGroup>
    <Folder Include="data\" />
    <Folder Include="data\raw\" />
    <Folder Include="data\raw\mendeley\" />
    <Folder Include="data\raw\chest_xray\" />
    <Folder Include="data\raw\symptom2disease\" />
    <Folder Include="checkpoints\" />
    <Folder Include="app\" />
    <Folder Include="models\" />
    <Folder Include="training\" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="data\Disease and symptoms dataset.csv" />
    <Content Include="data\Symptom2Disease.csv" />
    <Content Include="requirements.txt" />
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)\Python Tools\Microsoft.PythonTools.targets" />
  <!-- Uncomment the CoreCompile target to enable the Build command in
       Visual Studio and specify your pre- and post-build commands in
       the BeforeBuild and AfterBuild targets below. -->
  <!--<Target Name="CoreCompile" />-->
  <Target Name="BeforeBuild">
  </Target>
  <Target Name="AfterBuild">
  </Target>
</Project>